---
import PageLayout from "~/layouts/PageLayout.astro";
import PersonalProjects from "~/components/projects/PersonalProjects.astro";
import KingsWorldProjects from "~/components/projects/KingsWorldProjects.astro";
import MixtapeProjects from "~/components/projects/MixtapeProjects.astro";
---

<PageLayout
	title="Projects"
	description="View a collection of open-source GitHub projects that Seren maintains or contributes to"
	className="container"
>
	<div class="py-4">
		<h1 class="text-2xl leading-none font-semibold">Projects</h1>
		<p class="text-muted-foreground">
			A collection of my open-source GitHub projects
		</p>
	</div>
	<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
		<PersonalProjects />
		<KingsWorldProjects />
		<MixtapeProjects />
	</div>
</PageLayout>
